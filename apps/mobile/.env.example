# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# GitHub OAuth App credentials
# Create your OAuth App at: github.com/settings/developers
# Enable "Device Flow" in the OAuth App settings (no redirect URI needed).
# Authorization callback URL: leave blank (Device Flow does not use one).
EXPO_PUBLIC_GITHUB_CLIENT_ID=
