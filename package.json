{
  "name": "driftcode",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "mobile": "npm run start --workspace=apps/mobile",
    "mobile:android": "npm run android --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "web": "npm run dev --workspace=apps/web"
  },
  "devDependencies": {
    "metro": "~0.83.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "scheduler": "0.26.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
